# ─── Target environment ────────────────────────────────────────────────────────
# One of: local | dev | staging | prod
TEST_ENV=local

# ─── URLs (required when TEST_ENV=dev, staging or prod) ───────────────────────
# DEV_BASE_URL=https://app-dev.grupo5.oyd.solid.com.gt
# STAGING_BASE_URL=https://app-staging.grupo5.oyd.solid.com.gt
# PROD_BASE_URL=https://app.grupo5.oyd.solid.com.gt

# ─── Test credentials ──────────────────────────────────────────────────────────
# Administrador account (system_role=admin)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Conductor account (system_role=driver)
CONDUCTOR_EMAIL=conductor@example.com
CONDUCTOR_PASSWORD=