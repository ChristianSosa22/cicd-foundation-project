# ─── Target environment ────────────────────────────────────────────────────────
# One of: local | dev | staging | prod
TEST_ENV=local

# ─── URL overrides (optional when TEST_ENV=local) ──────────────────────────────
# BASE_URL overrides the default for the chosen environment
# BASE_URL=http://localhost:3000

# API_URL overrides the API base for auth and direct API calls
# API_URL=http://localhost:8080

# Per-environment URLs (used when TEST_ENV=dev|staging|prod)
# DEV_BASE_URL=http://<dev-alb-dns>
# DEV_API_URL=http://<dev-alb-dns>
# STAGING_BASE_URL=http://<staging-alb-dns>
# STAGING_API_URL=http://<staging-alb-dns>
# PROD_BASE_URL=http://<prod-alb-dns>
# PROD_API_URL=http://<prod-alb-dns>

# ─── Test credentials ──────────────────────────────────────────────────────────
# Administrador account (system_role=admin)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Conductor account (system_role=driver, vehicle approved)
CONDUCTOR_EMAIL=conductor@example.com
CONDUCTOR_PASSWORD=
