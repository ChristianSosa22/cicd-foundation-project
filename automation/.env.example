# ─── Target environment ────────────────────────────────────────────────────────
# One of: local | dev | prod
TEST_ENV=local

# ─── URLs (required when TEST_ENV=dev or prod) ────────────────────────────────
# DEV_BASE_URL=http://<dev-alb-dns>
# PROD_BASE_URL=http://<prod-alb-dns>

# ─── Test credentials ──────────────────────────────────────────────────────────
# Administrador account (system_role=admin)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Conductor account (system_role=driver)
CONDUCTOR_EMAIL=conductor@example.com
CONDUCTOR_PASSWORD=