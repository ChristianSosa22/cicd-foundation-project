# Local Terraform state files — may contain plaintext secrets and resource IDs
*.tfstate
*.tfstate.*

# Terraform working directory — provider binaries, module cache (large, machine-specific)
.terraform/
.terraform.tfstate.lock.info
.terraform.lock.hcl

# Variable values files — may contain secrets; allow only the dev environment file used by CI
*.tfvars
!envs/dev/dev.tfvars
!envs/staging/staging.tfvars
!envs/prod/prod.tfvars
# Saved plan output — binary, can contain sensitive data
tfplan*

# Crash logs from Terraform itself
crash.log
crash.*.log

# Lambda placeholder zip generated by archive_file data source
modules/compute/lambda_placeholder.zip

# Worker image: local node_modules if deps are installed outside Docker
# (the image is built by CI via worker/Dockerfile; package-lock.json is tracked)
modules/lambda/worker/node_modules/
# The root .gitignore ignores package-lock.json globally; the worker lockfile is
# required by `npm ci` in the Docker build, so keep it tracked.
!modules/lambda/worker/package-lock.json