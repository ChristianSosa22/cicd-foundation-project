# Copy to .env and fill in. Loaded by dotenv in src/config/env.ts.
NODE_ENV=development
PORT=8080

# PostgreSQL (RDS in cloud; local Postgres for dev)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/parking

# Auth — use a long random string (>= 16 chars)
JWT_SECRET=change-me-to-a-long-random-secret-string
JWT_EXPIRES_IN=8h

# AWS / S3 (receipts). Optional locally.
AWS_REGION=us-east-1
S3_BUCKET=

# Column encryption for plate_enc / phone_enc (data-model.md §8)
# ENCRYPTION_KEY = base64 of 32 random bytes (AES-256-GCM). Or resolve from Secrets Manager.
ENCRYPTION_KEY=
ENCRYPTION_KEY_SECRET_ID=
# HMAC key for plate_hash (unique lookup without decryption)
HMAC_KEY=
