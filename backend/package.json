{
  "name": "parking-backend",
  "version": "0.1.0",
  "private": true,
  "description": "API del Sistema de Reserva y Gestión de Parqueos (Express + Drizzle)",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:apply-sql": "psql \"$DATABASE_URL\" -f sql/schema.sql",
    "db:seed": "psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 --no-psqlrc -f sql/seed.sql",
    "db:init": "psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 --no-psqlrc -f sql/schema.sql -f sql/seed.sql",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.679.0",
    "@aws-sdk/client-secrets-manager": "^3.679.0",
    "@aws-sdk/s3-request-presigner": "^3.679.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "pdf-lib": "^1.17.1",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "qrcode": "^1.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.28.1",
    "eslint": "^9.14.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
